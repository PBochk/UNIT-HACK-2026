    \u043E\u0447\u043A\u0438. \u0423\u043B\u0443\u0447\u0448\u0430\u0439 \u0430\u0432\u0442\u043E\u043C\u0430\u0442.
    \u0417\u0430\u0440\u0430\u0431\u0430\u0442\u044B\u0432\u0430\u0439 \u0431\u043E\u043B\u044C\u0448\u0435!\n\u041D\u0430\u0431\u0435\u0440\u0438
    1.000 \u043E\u0447\u043A\u043E\u0432 \u0437\u0430 \u043E\u0434\u0438\u043D \u0440\u0430\u0443\u043D\u0434,
